<?xml version="1.0" ?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="test">
  <link name="base_link" />
  <joint name="hip" type="revolute">
    <parent link="base_link" />
    <child link="hip_link" />
    <limit effort="100.0" velocity="100.0" lower="-3.14159" upper="3.14159" />
  </joint>
  <link name="hip_link" />
  <joint name="thigh" type="revolute">
    <parent link="hip_link" />
    <child link="thigh_link" />
    <limit effort="100.0" velocity="100.0" lower="-3.14159" upper="3.14159" />
  </joint>
  <link name="thigh_link" />

  <ros2_control name="Test" type="system">
    <hardware>
      <plugin>mock_components/GenericSystem</plugin>
      <param name="calculate_dynamics">true</param>
    </hardware>
    <joint name="hip">
      <command_interface name="position" />
      <command_interface name="velocity" />
      <command_interface name="effort" />
      <state_interface name="position" />
      <state_interface name="velocity" />
      <state_interface name="effort" />
    </joint>
    <joint name="thigh">
      <command_interface name="position" />
      <command_interface name="velocity" />
      <command_interface name="effort" />
      <state_interface name="position" />
      <state_interface name="velocity" />
      <state_interface name="effort" />
    </joint>
    <sensor name="imu">
      <state_interface name="angular_velocity.x">
        <param name="initial_value">0.0</param>
      </state_interface>
      <state_interface name="angular_velocity.y">
        <param name="initial_value">0.0</param>
      </state_interface>
      <state_interface name="angular_velocity.z">
        <param name="initial_value">-9.81</param>
      </state_interface>
      <state_interface name="linear_acceleration.x">
        <param name="initial_value">0.0</param>
      </state_interface>
      <state_interface name="linear_acceleration.y">
        <param name="initial_value">0.0</param>
      </state_interface>
      <state_interface name="linear_acceleration.z">
        <param name="initial_value">0.0</param>
      </state_interface>
    </sensor>
  </ros2_control>
</robot>
